PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB Connection String (local or MongoDB Atlas)
# Local: mongodb://localhost:27017/library_management
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=your_mongodb_atlas_connection_string

# JWT secret key - use a long, random string in production
JWT_SECRET=any_long_random_secret_string

# OpenAI API Key for AI-powered features
OPENAI_API_KEY=sk-proj-xxxxx

# Google Gemini API Key for AI features
GEMINI_API_KEY=your_gemini_api_key

# Hugging Face API Token
HF_API_TOKEN=hf_xxxxx

# Razorpay credentials (test keys for development)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

FRONTEND_URL=https://your-vercel-app.vercel.app
NODE_ENV=production

# Supabase Storage credentials for PDF uploads
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_public_key
